{
  "manifest_version": 2,
  "name": "Image Red Toggle",
  "version": "0.1.0",
  "description": "Show a button on images to toggle them to a red placeholder and back.",
  "applications": {
    "gecko": {
      "id": "image-red-toggle@example.com",
      "strict_min_version": "78.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}

